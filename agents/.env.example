# Required: Google AI API key for Gemini
GOOGLE_API_KEY=your-gemini-api-key

# Optional: Socrata app token (increases rate limits from ~1/s to ~1000/s)
# Get one free at: https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# Cloud Run port (auto-set by Cloud Run, default 8080)
PORT=8080
